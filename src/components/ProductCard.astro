---
import { Rating } from "@/components/ui/rating"

type Status = 'in-stock' | 'low-stock' | 'out-of-stock';

interface Props {
  productId?: string;
  title: string;
  brand?: string;
  description?: string;
  ingredients?: string;
  image?: string;
  imageAlt?: string;
  status?: Status;
  category: string;
  subcategory?: string;
  price?: string;
  rating?: number;
  reviewCount?: number;
  href?: string;
}

const {
  productId,
  title,
  brand,
  description,
  ingredients,
  image = '/unfound-placeholder.svg',
  imageAlt = title,
  status = 'in-stock',
  category,
  subcategory,
  price,
  rating,
  reviewCount,
  href = '#',
} = Astro.props;

const isPlaceholder = image === '/unfound-placeholder.svg';

const dotColor: Record<Status, string> = {
  'in-stock':     '#79A465',
  'low-stock':    '#F59D76',
  'out-of-stock': '#B5514C',
};

const dotTitle: Record<Status, string> = {
  'in-stock':     'In stock',
  'low-stock':    'Low stock',
  'out-of-stock': 'Out of stock',
};

const searchText = [brand, title].filter(Boolean).join(' ');
---

<a
  href={href}
  data-category={category}
  data-subcategory={subcategory}
  data-search={searchText.toLowerCase()}
  data-open-modal="true"
  data-modal-id={productId}
  data-modal-title={title}
  data-modal-brand={brand}
  data-modal-reviews={reviewCount}
  data-modal-image={image}
  data-modal-price={price}
  data-modal-status={status}
  data-modal-rating={rating}
  data-modal-desc={description}
  data-modal-ingredients={ingredients}
  class="product-card flex flex-col no-underline rounded-2xl p-3 transition-all duration-200 group hover:shadow-lg hover:-translate-y-0.5 cursor-pointer"
>
  <div class="bg-white dark:bg-[#3a2520] rounded-xl aspect-square mb-3 overflow-hidden flex items-center justify-center p-4">
    {isPlaceholder ? (
      <>
        <img src="/unfound-placeholder.svg"      alt={imageAlt} class="w-1/2 h-1/2 object-contain opacity-50 dark:hidden" loading="lazy" />
        <img src="/unfound-placeholder-dark.svg" alt={imageAlt} class="w-1/2 h-1/2 object-contain opacity-50 hidden dark:block" loading="lazy" />
      </>
    ) : (
      <img src={image} alt={imageAlt} class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-300" loading="lazy" />
    )}
  </div>

  <div class="px-1 mt-1 flex-1">
    {brand && (
      <p class="text-[13px] font-bold uppercase tracking-widest text-[#a45302] dark:text-[#A9AFA0] m-0 mb-0.5">{brand}</p>
    )}
    <div class="flex items-start justify-between gap-2">
      <span class="font-bold text-[#3a2a20] dark:text-[#f5d4c0] text-base leading-snug">{title}</span>
      <span
        class="w-4 h-4 rounded-full shrink-0 mt-1 border border-white/40"
        style={`background-color: ${dotColor[status]};`}
        title={dotTitle[status]}
      ></span>
    </div>
  </div>

  <div class="px-1 mt-1.5 flex items-center">
    <Rating rating={rating} class="text-[#eaa640]" />
    {price && (
      <p class="ml-auto px-2 py-0.5 font-bold text-[#774A33] dark:text-[#dba88f] bg-[#fcefe9] dark:bg-[#3a2520] rounded-md m-0 text-m">{price}</p>
    )}
  </div>

</a>

<style>
  .product-card {
    background-color: #fad5c5;
    border: 2px solid #e8c4b8;
  }
  :global(.dark) .product-card {
    background-color: #4e362d;
    border-color: #7a4a38;
  }
</style>
