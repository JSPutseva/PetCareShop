---
interface NavItem {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
}

interface Props {
  items: NavItem[];
  currentPath?: string;
}

const { items, currentPath = Astro.url.pathname } = Astro.props;
---

<!-- Mobile overlay -->
<div
  id="sidebar-overlay"
  class="fixed inset-0 z-30 bg-black/40 hidden md:hidden"
  aria-hidden="true"
></div>

<!-- Sidebar drawer -->
<aside
  id="sidebar"
  class="
    fixed top-[48px] left-0 z-40
    w-50 h-[calc(100vh-48px)]
    bg-[#e8c4b8] dark:bg-[#343434]
    px-3 pt-6 pb-8
    font-['Inria_Sans',sans-serif] overflow-y-auto
    -translate-x-full md:translate-x-0
    transition-transform duration-300 ease-in-out
  "
  aria-label="Table of contents"
>
  <nav>
    <ol class="list-none m-0 p-0 flex flex-col gap-0.5">
      {items.map((item, i) => (
        <li>
          <a
            href={item.href}
            aria-current={currentPath === item.href ? 'page' : undefined}
            class:list={[
              'flex items-baseline gap-1 no-underline rounded px-1 py-0.5 text-xl font-semibold leading-snug transition-all duration-150',
              currentPath === item.href
                ? ''
                : 'text-[#774A33] dark:text-[#FFC195] hover:bg-[#DEAFAA] hover:text-white dark:hover:bg-[#C78E66]',
            ]}
          >
            <span class="tabular-nums shrink-0">{i + 1}.</span>
            {item.label}
          </a>

          {item.children && item.children.length > 0 && (
            <ul class="list-none m-0 mt-0.5 mb-1 p-0 flex flex-col gap-0.5 pl-1">
              {item.children.map(child => (
                <li>
                  <a
                    href={child.href}
                    aria-current={currentPath === child.href ? 'page' : undefined}
                    class:list={[
                      'flex items-baseline gap-1.5 no-underline rounded px-1 py-0.5 text-m leading-snug transition-all duration-150',
                      currentPath === child.href
                        ? ''
                        : 'text-[#774A33] dark:text-[#e08b4e] hover:text-white',
                    ]}
                  >
                    <span class="text-[#708d62] dark:text-[#a62920] font-light shrink-0" aria-hidden="true">|</span>
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ol>
  </nav>
</aside>

<!-- Spacer -->
<div class="hidden md:block w-40 shrink-0" aria-hidden="true"></div>

<script>
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  const toggleBtn = document.getElementById('sidebar-toggle');

  function openSidebar() {
    sidebar?.classList.remove('-translate-x-full');
    overlay?.classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
  }

  function closeSidebar() {
    sidebar?.classList.add('-translate-x-full');
    overlay?.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }

  toggleBtn?.addEventListener('click', () => {
    const isOpen = !sidebar?.classList.contains('-translate-x-full');
    isOpen ? closeSidebar() : openSidebar();
  });

  overlay?.addEventListener('click', closeSidebar);

  sidebar?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth < 768) closeSidebar();
    });
  });
</script>