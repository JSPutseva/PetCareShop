---
interface Props {
  animal?: 'cats' | 'dogs';
}
const { animal } = Astro.props;
---

<nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 sm:px-6 bg-[#7a9070] dark:bg-[#443331] h-12">

  <!-- Left: burger + animal switcher -->
  <div class="flex items-center gap-2">
    <button
      id="sidebar-burger"
      aria-label="Toggle categories"
      class="md:hidden p-1.5 rounded-md border-0 cursor-pointer text-[#f5f0eb] bg-transparent hover:bg-white/20 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6"  x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <a
      href="/cats"
      class:list={[
        'px-5 py-1.5 rounded-md text-[#f5f0eb] text-sm font-semibold tracking-wide no-underline transition-all duration-200',
        animal === 'cats' ? 'bg-[#1e3d34] dark:bg-[#1C0502]' : 'bg-[#2d5a4e] dark:bg-[#65231B] hover:bg-[#1e3d34] dark:hover:bg-[#63342E]',
      ]}
    >Cats</a>
    <a
      href="/dogs"
      class:list={[
        'px-5 py-1.5 rounded-md text-[#f5f0eb] text-sm font-semibold tracking-wide no-underline transition-all duration-200',
        animal === 'dogs' ? 'bg-[#1e3d34] dark:bg-[#1C0502]' : 'bg-[#2d5a4e] dark:bg-[#65231B] hover:bg-[#1e3d34] dark:hover:bg-[#63342E]',
      ]}
    >Dogs</a>
  </div>

  <!-- Right: search + font size -->
  <div class="flex items-center gap-2">

    <div id="search-wrap" class="flex items-center gap-1">
      <input
        id="nav-search"
        type="search"
        placeholder="Search products…"
        aria-label="Search products"
        class="
          hidden sm:block
          w-40 md:w-56
          px-3 py-1 rounded-md text-sm
          bg-white/20 text-[#f5f0eb] placeholder-[#d4e8d0]
          border border-white/30 outline-none
          focus:bg-white/30 focus:w-64 transition-all duration-200
        "
      />
      <button
        id="search-toggle"
        aria-label="Search"
        class="sm:hidden p-1.5 rounded-md bg-transparent border-0 cursor-pointer text-[#f5f0eb] hover:bg-white/20 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
    </div>

    <div id="dropdown-font" class="relative">
      <button
        id="font-trigger"
        aria-label="Font size"
        class="px-3 py-1 rounded-md border-0 cursor-pointer bg-[#e8c4b8] text-[#2d5a4e] dark:text-[#4A2C28] font-bold hover:bg-[#d4a898] transition-colors duration-200 flex items-baseline gap-px leading-none"
      >
        <span id="font-icon-big"  style="font-size:13px">A</span>
        <span id="font-icon-small" style="font-size:9px">A</span>
      </button>
      <div class="absolute right-0 top-full h-2 w-full"></div>
      <ul
        id="menu-font"
        class="
          absolute top-[calc(100%+8px)] right-0 z-50
          min-w-30
          bg-[#2d5a4e] dark:bg-[#32130F]
          rounded-md py-1.5
          shadow-[0_8px_24px_rgba(0,0,0,0.22)] list-none m-0
          invisible opacity-0 translate-y-1
          transition-all duration-150
        "
      >
        {(['100', '115', '130'] as const).map((size, i) => (
          <li>
            <button
              data-size={size}
              class:list={[
                'font-size-opt w-full text-left px-4 py-2 text-[#f5f0eb] text-sm border-0 bg-transparent cursor-pointer hover:bg-[#DED8BF] dark:hover:bg-[#C79089] hover:text-[#29524A] transition-colors duration-150',
                i < 2 && 'border-b border-[rgba(245,240,235,0.12)]',
              ]}
            >{(['Standard', 'Medium', 'Large'])[i]}</button>
          </li>
        ))}
      </ul>
    </div>

  </div>
</nav>

<div class="h-[48px]" aria-hidden="true"></div>

<!-- Mobile search bar -->
<div
  id="mobile-search-bar"
  class="hidden sm:hidden fixed top-12 left-0 right-0 z-40 bg-[#7a9070] dark:bg-[#443331] px-4 py-2"
>
  <input
    id="nav-search-mobile"
    type="search"
    placeholder="Search products…"
    aria-label="Search products"
    class="w-full px-3 py-1.5 rounded-md text-sm bg-white/20 text-[#f5f0eb] placeholder-[#d4e8d0] border border-white/30 outline-none focus:bg-white/30"
  />
</div>

<script>
  const FONT_KEY = 'petcare-font-size';
  const FONT_ICON_SIZES: Record<string, [number, number]> = {
    '100': [13, 9], '115': [15, 10], '130': [17, 12],
  };

  const savedSize = localStorage.getItem(FONT_KEY) || '100';
  document.documentElement.style.fontSize = savedSize === '100' ? '' : `${savedSize}%`;

  function syncFontIcon(size: string) {
    const [big, small] = FONT_ICON_SIZES[size] ?? FONT_ICON_SIZES['100'];
    (document.getElementById('font-icon-big')  as HTMLElement).style.fontSize = `${big}px`;
    (document.getElementById('font-icon-small') as HTMLElement).style.fontSize = `${small}px`;
  }
  syncFontIcon(savedSize);

  function syncFontButtons() {
    const current = localStorage.getItem(FONT_KEY) || '100';
    document.querySelectorAll<HTMLButtonElement>('.font-size-opt').forEach(btn => {
      btn.classList.toggle('font-bold', btn.dataset.size === current);
      btn.classList.toggle('bg-[rgba(255,255,255,0.12)]', btn.dataset.size === current);
    });
  }

  const fontMenu = document.getElementById('menu-font')!;
  document.getElementById('font-trigger')?.addEventListener('click', e => {
    e.stopPropagation();
    const opening = fontMenu.classList.contains('invisible');
    fontMenu.classList.toggle('invisible', !opening);
    fontMenu.classList.toggle('opacity-0',  !opening);
    fontMenu.classList.toggle('translate-y-1', !opening);
    if (opening) syncFontButtons();
  });

  document.querySelectorAll<HTMLButtonElement>('.font-size-opt').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const size = btn.dataset.size ?? '100';
      localStorage.setItem(FONT_KEY, size);
      document.documentElement.style.fontSize = size === '100' ? '' : `${size}%`;
      syncFontButtons();
      syncFontIcon(size);
      fontMenu.classList.add('invisible', 'opacity-0', 'translate-y-1');
    });
  });

  document.addEventListener('click', e => {
    if (!document.querySelector('nav')?.contains(e.target as Node)) {
      fontMenu.classList.add('invisible', 'opacity-0', 'translate-y-1');
    }
  });

  function dispatchSearch(query: string) {
    document.dispatchEvent(new CustomEvent('petcare:search', { detail: { query } }));
  }

  document.getElementById('nav-search')?.addEventListener('input', e => {
    dispatchSearch((e.target as HTMLInputElement).value.trim());
  });

  document.getElementById('nav-search-mobile')?.addEventListener('input', e => {
    dispatchSearch((e.target as HTMLInputElement).value.trim());
  });

  const mobileBar = document.getElementById('mobile-search-bar')!;
  document.getElementById('search-toggle')?.addEventListener('click', () => {
    const hidden = mobileBar.classList.contains('hidden');
    mobileBar.classList.toggle('hidden', !hidden);
    if (hidden) (document.getElementById('nav-search-mobile') as HTMLInputElement)?.focus();
  });

  document.getElementById('sidebar-burger')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('petcare:sidebar-toggle'));
  });
</script>
