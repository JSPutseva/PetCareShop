---
import { cn } from "@/lib/utils"

interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<button
  data-slot="theme-toggle"
  aria-label="Toggle theme"
  class={cn(
    "relative w-8 h-8 flex items-center justify-center rounded-md border-0 cursor-pointer bg-transparent text-[#f5f0eb] hover:bg-white/20 transition-colors",
    className
  )}
>
  <!-- Light mode -->
  <svg
    class="sun-icon size-[1.1em]"
    xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
    fill="none" stroke="currentColor" stroke-width="2"
    stroke-linecap="round" stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="4"/>
    <line x1="12" y1="2"  x2="12" y2="4"/>
    <line x1="12" y1="20" x2="12" y2="22"/>
    <line x1="4.22" y1="4.22"  x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="2"  y1="12" x2="4"  y2="12"/>
    <line x1="20" y1="12" x2="22" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>

  <!-- Dark mode -->
  <svg
    class="moon-icon size-[1.1em]"
    xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
    fill="none" stroke="currentColor" stroke-width="2"
    stroke-linecap="round" stroke-linejoin="round"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script is:inline>
  if (!window.__themeHandlersInitialized) {
    window.__themeHandlersInitialized = true;
    document.querySelectorAll("[data-slot='theme-toggle']").forEach((toggle) => {
      toggle.addEventListener("click", () => {
        const el = document.documentElement;
        el.classList.add("no-transitions");
        el.classList.toggle("dark");
        const isDark = el.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        el.setAttribute("data-theme", isDark ? "dark" : "light");
        requestAnimationFrame(() => el.classList.remove("no-transitions"));
      });
    });
  }
</script>

<style>
  :global(html.no-transitions *) {
    transition: none !important;
    animation-duration: 0s !important;
  }

  .sun-icon  { display: block; }
  .moon-icon { display: none;  }
  :global(.dark) .sun-icon  { display: none;  }
  :global(.dark) .moon-icon { display: block; }
</style>
